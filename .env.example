# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API Key for Embeddings (used in ingestion)
OPENAI_API_KEY=your_openai_api_key_here

# Neo4j Database Configuration
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Optional Neo4j Tuning
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_ACQUISITION_TIMEOUT=30
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_MAX_TRANSACTION_RETRY_TIME=30

# Extraction Pipeline Tuning
EXTRACTION_CONCURRENCY_LIMIT=5
EXTRACTION_BATCH_SIZE=1

# Frontend / Next.js Backend Routing
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Playwright Local Overrides
PLAYWRIGHT_FRONTEND_PORT=3000
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
SMOKE_DOCUMENT_ID=doc-transformer
